# Enterprise Management System - Environment Configuration Example
# Copy this file to .env and fill in your actual values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=enterprise_system
DATABASE_USER=postgres
DATABASE_PASSWORD=your_secure_password

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
SERVER_PORT=8080
SERVER_HOST=localhost

# ============================================================================
# JWT CONFIGURATION
# ============================================================================
# Generate a secure secret key (minimum 32 characters recommended)
# You can generate one with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_min_32_characters_long_for_security
JWT_TTL=3600

# ============================================================================
# DATABASE MIGRATION CONFIGURATION
# ============================================================================
# Set to "latest" to run all migrations or specific version number
# Examples: "latest", "1", "3", "20260506112820"
MIGRATE_TO_VERSION=latest

# Path to migration files (relative to project root)
MIGRATION_LOCATION=./internal/infra/database/migrations

# ============================================================================
# FILE STORAGE CONFIGURATION
# ============================================================================
# Location where uploaded files will be stored
FILE_STORAGE_LOCATION=./storage

# ============================================================================
# LOGGING CONFIGURATION (Optional)
# ============================================================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Allowed origins for CORS requests (comma-separated)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ============================================================================
# DEVELOPMENT/PRODUCTION
# ============================================================================
# Environment: development, production, staging
ENVIRONMENT=development

# ============================================================================
# NOTES
# ============================================================================
# 1. Never commit actual .env file to git
# 2. Use .env.local for local overrides
# 3. Use different values for development, staging, and production
# 4. Keep JWT_SECRET very secure in production
# 5. Use strong database passwords in production
# 6. Set FILE_STORAGE_LOCATION to appropriate path with proper permissions
# 7. For production: Set ENVIRONMENT=production
# 8. For production: Set appropriate MIGRATE_TO_VERSION
